{
  "name": "opensource-api",
  "version": "1.12.0",
  "description": "A free and public Open Source API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prepare": "husky",
    "test": "mocha test/**/*.test.js --exit",
    "env": "cp .env.example .env"
  },
  "author": "Pradumna Saraf",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.7.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "chai": "^6.2.2",
    "chai-http": "^5.1.2",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.2.0",
    "mocha": "^11.7.6",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.5"
  },
  "lint-staged": {
    "*.{js,md}": "prettier --write",
    "*.js": "eslint --fix"
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  }
}
